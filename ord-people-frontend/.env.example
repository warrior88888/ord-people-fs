# Frontend environment variables.
# Copy this file to .env.local (gitignored) for local overrides.

# Public API base URL embedded into the build. Required.
# In local dev "/api/v1" lets the Vite proxy forward to the backend (see VITE_DEV_API_PROXY_TARGET),
# so the browser sees same-origin and the session_id cookie works without CORS changes.
# In production set the absolute URL, e.g. https://backend.example.com/api/v1
VITE_API_BASE_URL=/api/v1

# Public base URL for media assets (S3 / CDN). Required.
VITE_MEDIA_BASE_URL=https://media.example.com

# Dev-only: where the Vite proxy forwards "/api" during `npm run dev`.
# Not embedded into the production build.
VITE_DEV_API_PROXY_TARGET=http://localhost:8000
